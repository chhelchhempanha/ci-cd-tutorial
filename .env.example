PORT=8080
NODE_ENV=development

# PostgreSQL/Neon Database Configuration
# Get these values from your Neon console: https://console.neon.tech
PGHOST=your-neon-host.c-2.us-east-2.aws.neon.tech
PGDATABASE=neondb
PGUSER=neondb_owner
PGPASSWORD=your_password_here
PGPORT=5432
PGSSLMODE=require
PGCHANNELBINDING=require
